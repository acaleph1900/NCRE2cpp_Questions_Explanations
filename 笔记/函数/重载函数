#include <iostream>
using namespace std;

int function(int x , int y) {
	return x + y;
 }

double function(double x, double y) {
	return x - y;
}
//函数重载的条件：
//1.函数名相同
//2.参数个数不同，或者参数类型不同

int main() {
	int a = 5, b = 10;
	double c = 10.5, d = 5.5;
	cout << "int : " << function(a, b) << endl;
	cout << "double : " << function(c, d) << endl;

	return 0;
}
