#include <iostream>
using namespace std;

class function {//建立一个类
public:
	int function2(int a);
	void function3() {
		cout << "a sentence" << endl;
	}
};

int function::function2(int a) {
	// ::作用域解析运算符
	//用来标识函数属于哪个类
	// ::左边是类名，右边是函数名
	//在这里，函数function2属于类function
	return a * 2;
}

int main() {
	function x;//生成一个类的对象x
	cout << x.function2(5) << endl;//调用function2，传入参数5
	x.function3();//调用function3

	return 0;
}
