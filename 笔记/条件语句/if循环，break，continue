#include <iostream>
using namespace std;
int main()
{
	for (int a = 1; a <= 5; a++)	//先赋值a，再进行条件判断
	{
		cout << a << endl;
	}
	//输出结果后，执行a++
	// 进行循环
	//直到a>5，不满足条件

	for (int b = 1;  b <= 5;  b=b+2)
	{
		cout << b << endl;
	}
	//输出结果1
	// 执行b=b+2	，得到3
	//最后输出1，3，5
	
	for (int d = 1; d <= 5; d++)
	{
		if (d == 3)
		{
			break;	//跳出循环
		}
		cout << d << endl;
	} 
	//输出结果1，2

	for (int c = 1; c <= 5; c++)
	{
		if (c == 3)
		{
			continue;	//跳过本次循环，继续下一次循环
		}
		cout << c << endl;
	}
	//输出结果1，2，4，5
	return 0;
}
