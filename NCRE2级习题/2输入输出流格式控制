#include<iostream>
#include<iomanip>
using namespace std;
int main() {
	int s[] = { 123,234 };
	cout << right << setfill('*') << setw(6);
	//right，设置输出右对齐
	//setfill('*')，设置填充字符为*
	// setw(6)，设置输出宽度为6，一次性生效
	for (int i = 0; i < 2; i++) { cout << s[i] << endl; }
	return 0;
}
/*第一次循环，i = 0时
cout << s[0];
123占3个字符，需要填充3个字符
填充字符放在左侧 ，输出 ***123

第二次循环，i = 1时
setw(6)是一次性的，但 setfill('*')和 right会持续生效
没有新的 setw(6)设置，字段宽度恢复为默认
不需要填充，输出 234
*/

